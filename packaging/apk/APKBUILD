# Maintainer: UberMetroid <ubermetroid@users.noreply.github.com>
pkgname=rwifi
pkgver=TEMPLATE_VERSION
pkgrel=1
pkgdesc="A project template for creating unified local terminal utilities in Rust"
url="https://github.com/local76/rWifi"
arch="x86_64"
license="MIT"
depends=""
makedepends="cargo"
source="$pkgname-$pkgver.tar.gz"

build() {
	cargo build --release --locked
}

package() {
	install -Dm755 target/release/rwifi "$pkgdir"/usr/bin/rwifi
	install -Dm644 packaging/desktop/rwifi.desktop "$pkgdir"/usr/share/applications/rwifi.desktop
	install -Dm644 assets/brand/app_icon.png "$pkgdir"/usr/share/pixmaps/rwifi.png
}
